{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "lib": ["ES2023", "DOM"],
    "moduleResolution": "nodenext",
    "allowJs": false,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": true,

    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    /* Build settings */
    "composite": true,
    "declaration": true,
    "declarationMap": true
  }
}
