{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "typescript": true,
  "ignore": ["**/node_modules/**, **/dist/**", "**/.storybook/**"],
  "entry": ["**/*.test.ts", "**/*.test.tsx"],
  "workspaces": {
    "packages/magic-client": {
      "ignore": ["env.d.ts"]
    },
    "packages/magic-products": {
      "ignoreDependencies": [
        "fraction.js",
        "@graph/core",
        "@graph/plugins",
        "@graph/primitives"
      ]
    },
    "packages/graph-core": {
      "ignoreDependencies": ["fraction.js"]
    },
    "packages/magic-shared": {
      "ignoreDependencies": ["@graph/primitives"]
    }
  }
}
