{
  "name": "@core/components",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*.vue": {
      "types": "./dist/types/*.vue.d.ts",
      "default": "./src/*.vue"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@core/utils": "workspace:*",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.11",
    "vue": "catalog:"
  }
}
