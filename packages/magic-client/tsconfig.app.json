{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "rootDir": "./src",
    "types": ["vite/client"],
    "outDir": "./dist/types",
    "allowImportingTsExtensions": true,
    "paths": {
      "@magic/ui/*": ["../ui/src/*"],
      "@magic/products/*": ["../magic-products/src/*"]
    }
  },
  "references": [{ "path": "../ui" }, { "path": "../magic-products" }],
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue"]
}
