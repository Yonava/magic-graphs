{
  "name": "@graph/plugins-shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./theme": {
      "types": "./dist/types/theme/index.d.ts",
      "default": "./src/theme/index.ts"
    },
    "./plugins": {
      "types": "./dist/types/plugins/index.d.ts",
      "default": "./src/plugins/index.ts"
    },
    "./computed-tokens": {
      "types": "./dist/types/computed-tokens/index.d.ts",
      "default": "./src/computed-tokens/index.ts"
    },
    "./drag": {
      "types": "./dist/types/drag/index.d.ts",
      "default": "./src/drag/index.ts"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "dependencies": {
    "@graph/primitives": "workspace:*",
    "@graph/core": "workspace:*",
    "@magic/shapes": "workspace:*",
    "@magic/utils": "workspace:*"
  },
  "devDependencies": {
    "ts-essentials": "^10.2.0"
  }
}
