{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["vite/client"],
    "outDir": "./dist/types",
    "paths": {
      "@magic/canvas/*": ["../ui/src/*"],
      "@magic/shapes/*": ["../products/src/*"]
    }
  },
  "references": [{ "path": "../ui" }, { "path": "../products" }],
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "../../types"],
  "exclude": ["./dist", "**/node_modules"]
}
