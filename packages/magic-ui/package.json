    },
    "./ToggleButtonGroup": {
      "types": "./dist/types/components/toggle-button-group/ToggleButtonGroup.vue.d.ts",
      "default": "./src/components/toggle-button-group/ToggleButtonGroup.vue"
    },
    "./ToggleButtonGroupItem": {
      "types": "./dist/types/components/toggle-button-group/ToggleButtonGroupItem.vue.d.ts",
      "default": "./src/components/toggle-button-group/ToggleButtonGroupItem.vue"
    },
    "./LensChip": {
      "types": "./dist/types/product/LensChip.vue.d.ts",
      "default": "./src/product/LensChip.vue"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@core/components": "workspace:*",
    "@magic/shared": "workspace:*"
  },
  "devDependencies": {
    "vue": "catalog:"
  }
}
