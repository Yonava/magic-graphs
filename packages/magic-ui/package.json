{
  "name": "@magic/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./Button": {
      "types": "./dist/types/components/button/Button.vue.d.ts",
      "default": "./src/components/button/Button.vue"
    },
    "./Well": {
      "types": "./dist/types/components/layout/Well.vue.d.ts",
      "default": "./src/components/layout/Well.vue"
    },
    "./HStack": {
      "types": "./dist/types/components/layout/HStack.vue.d.ts",
      "default": "./src/components/layout/HStack.vue"
    },
    "./VStack": {
      "types": "./dist/types/components/layout/VStack.vue.d.ts",
      "default": "./src/components/layout/VStack.vue"
    },
    "./Icon": {
      "types": "./dist/types/components/icon/Icon.vue.d.ts",
      "default": "./src/components/icon/Icon.vue"
    },
    "./IconButton": {
      "types": "./dist/types/components/icon-button/IconButton.vue.d.ts",
      "default": "./src/components/icon-button/IconButton.vue"
    },
    "./Tooltip": {
      "types": "./dist/types/components/tooltip/Tooltip.vue.d.ts",
      "default": "./src/components/tooltip/Tooltip.vue"
    },
    "./Dropdown": {
      "types": "./dist/types/components/dropdown/Dropdown.vue.d.ts",
      "default": "./src/components/dropdown/Dropdown.vue"
    },
    "./DropdownItem": {
      "types": "./dist/types/components/dropdown/DropdownItem.vue.d.ts",
      "default": "./src/components/dropdown/DropdownItem.vue"
    },
    "./ToggleButton": {
      "types": "./dist/types/components/toggle-button/ToggleButton.vue.d.ts",
