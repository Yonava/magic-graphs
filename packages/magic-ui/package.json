{
  "name": "@magic/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./Button": {
      "types": "./dist/types/components/button/Button.vue.d.ts",
      "default": "./src/components/button/Button.vue"
    },
    "./Well": {
      "types": "./dist/types/components/layout/Well.vue.d.ts",
      "default": "./src/components/layout/Well.vue"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@core/components": "workspace:*",
    "@magic/shared": "workspace:*"
  },
  "devDependencies": {
    "vue": "catalog:"
  }
}
