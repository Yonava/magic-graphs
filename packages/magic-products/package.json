      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@core/utils": "workspace:*",
    "@graph/core": "workspace:*",
    "@graph/plugins": "workspace:*",
    "@graph/primitives": "workspace:*",
    "@graph/create-graph": "workspace:*",
    "@magic/shared": "workspace:*",
    "@mdi/js": "^7.4.47",
    "fraction.js": "^5.3.4",
    "tinycolor2": "catalog:"
  },
  "devDependencies": {
    "ts-essentials": "^10.2.0",
    "@types/tinycolor2": "catalog:"
  }
