{
  "name": "@magic/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*.vue": {
      "types": "./dist/types/*.vue.d.ts",
      "default": "./src/*.vue"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build:types": "vue-tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@graph/core": "workspace:*",
    "@graph/plugins": "workspace:*",
    "@graph/create-graph": "workspace:*",
    "@graph/vue": "workspace:*",
    "@graph/theme-presets": "workspace:*",
    "@canvas/surface": "workspace:*",
    "@core/utils": "workspace:*"
  },
  "devDependencies": {
    "vue": "catalog:"
  }
}
