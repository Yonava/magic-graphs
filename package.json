{
  "name": "magic-graphs",
  "version": "1.0.0",
  "scripts": {
    "build": "pnpm --filter client build",
    "test": "vitest",
    "format": "prettier -w .",
    "dev": "pnpm --filter client dev",
    "build:types": "vue-tsc -b tsconfig.json",
    "clean:nuke": "rm -rf node_modules pnpm-lock.yaml packages/*/dist && pnpm i && pnpm build:types",
    "build:types:force": "vue-tsc -b tsconfig.json --clean && vue-tsc -b tsconfig.json"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.2.1",
    "@vitejs/plugin-vue": "^5.0.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.6"
    }
  }
}
